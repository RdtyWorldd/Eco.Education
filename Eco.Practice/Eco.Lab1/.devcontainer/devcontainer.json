{
    "name": "ECO Framework Dev Container",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {}
    },
    "runArgs": [
        "--platform=linux/amd64"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools"
            ]
        }
    },
    "remoteUser": "root",
    "mounts": [
        // Монтируем текущую рабочую папку
        "source=${localWorkspaceFolder},target=/workspace,type=bind",
        // Монтируем библиотеки с хоста в контейнер
        "source=/Users/rdtyworldd/Documents/peerf_practice/libs/Eco.FrameWork,target=/opt/eco_framework,type=bind",
        "source=/Users/rdtyworldd/Documents/peerf_practice/libs/Eco.FrameWork.RT,target=/opt/eco_framework_rt,type=bind"
    ],
    // Добавляем переменные окружения для контейнера
    "containerEnv": {
        "ECO_FRAMEWORK": "/opt/eco_framework",
        "ECO_FRAMEWORK_RT": "/opt/eco_framework_rt"
    }
}
