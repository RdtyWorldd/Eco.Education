ifeq ($(TARGET), 1)
OUT_TARGET = EcoLab2UnitTest
ifeq ($(DEBUG), 1)
CONFIG_TARGET = StaticDebug
CCFLAGS_TARGET = -Wall -O3 -g -DECO_LIB
else
CONFIG_TARGET = StaticRelease
CCFLAGS_TARGET = -O3 -DECO_LIB
endif
else
OUT_TARGET = EcoLab2UnitTest
ifeq ($(DEBUG), 1)
CONFIG_TARGET = DynamicDebug
CCFLAGS_TARGET = -Wall -O3 -g -DECO_DLL
else
CONFIG_TARGET = DynamicRelease
CCFLAGS_TARGET = -O3 -DECO_DLL
endif
endif

SRC = \
../../../UnitTestFiles/SourceFiles/EcoLab2.c

INCLUDES = \
-I ../../../HeaderFiles \
-I ../../../SharedFiles \
-I $(ECO_FRAMEWORK)/Eco.Core1/SharedFiles \
-I $(ECO_FRAMEWORK)/Eco.InterfaceBus1/SharedFiles \
-I $(ECO_FRAMEWORK)/Eco.FileSystemManagement1/SharedFiles \
-I $(ECO_FRAMEWORK)/Eco.MemoryManager1/SharedFiles

OBJ = $(SRC:.c=.o)

OUT = $(OUT_TARGET)
OUT_DIR = ../../../BuildFiles/Linux/x86_64/$(CONFIG_TARGET)

# Runtime folder for dynamic component .so files used by EcoLab2.
# Place EcoLab2 dependencies here when TARGET=0:
#   F87CD666E6314B33B2B4508FDCD4BE15.so (EcoLab2)
#   1F5DF16EE1BF43B999A434ED38FE8F3A.so (EcoLab1)
#   4828F6552E4540E78121EBD220DC360E.so (EcoCalculatorA)
#   AE202E543CE54550899603BD70C62565.so (EcoCalculatorB)
#   3A8E44677E82475CB4A3719ED8397E61.so (EcoCalculatorD)
#   872FEF1DE3314B87AD44D1E7C232C2F0.so (EcoCalculatorE)
COMPONENTS_DIR = $(OUT_DIR)/components

CC = gcc
RM = rm -f

CCFLAGS = $(CCFLAGS_TARGET) -DECO_LINUX -DECO_X86_64 -DUGUID_UTILITY

FRAMEWORK_LIB_DIR = \
-L $(ECO_FRAMEWORK)/Eco.InterfaceBus1/BuildFiles/Linux/x86_64/StaticRelease \
-L $(ECO_FRAMEWORK)/Eco.FileSystemManagement1/BuildFiles/Linux/x86_64/StaticRelease \
-L $(ECO_FRAMEWORK)/Eco.MemoryManager1/BuildFiles/Linux/x86_64/StaticRelease \
-L $(ECO_FRAMEWORK)/Eco.System1/BuildFiles/Linux/x86_64/StaticRelease

# Additional directories for component static libraries in ECO_LIB mode.
# Example:
# make -f MakefileExe TARGET=1 EXTRA_COMPONENT_LIB_DIRS="-L /path/to/Eco.Lab1/BuildFiles/... -L /path/to/Eco.CalculatorA/BuildFiles/..."
EXTRA_COMPONENT_LIB_DIRS ?=

COMMON_LIBS = $(FRAMEWORK_LIB_DIR) -lm -lc -lgcc -ldl \
-l00000000000000000000000053595333 \
-l00000000000000000000000042757331 \
-l0000000000000000000000004D656D31 \
-l00000000000000000000000046534D31

ifeq ($(TARGET), 1)
LIB_DIR = -L ../../../BuildFiles/Linux/x86_64/$(CONFIG_TARGET) $(EXTRA_COMPONENT_LIB_DIRS)
COMPONENT_STATIC_LIBS = \
-lF87CD666E6314B33B2B4508FDCD4BE15 \
-l1F5DF16EE1BF43B999A434ED38FE8F3A \
-l4828F6552E4540E78121EBD220DC360E \
-lAE202E543CE54550899603BD70C62565 \
-l3A8E44677E82475CB4A3719ED8397E61 \
-l872FEF1DE3314B87AD44D1E7C232C2F0
LIBS = $(LIB_DIR) $(COMMON_LIBS) $(COMPONENT_STATIC_LIBS)
else
# In ECO_DLL mode components are loaded dynamically at runtime.
# Keep .so files in $(COMPONENTS_DIR) and start executable with:
#   LD_LIBRARY_PATH=$(COMPONENTS_DIR):$$LD_LIBRARY_PATH
LIBS = $(COMMON_LIBS)
endif

.PHONY: all clean info

all: info $(OUT)

info:
	@echo "Build config: $(CONFIG_TARGET)"
	@echo "Runtime component directory: $(COMPONENTS_DIR)"

%.o: %.c
	$(CC) $(INCLUDES) $(CCFLAGS) -c $< -o $@

$(OUT): $(OBJ)
	mkdir -p $(OUT_DIR)
	mkdir -p $(COMPONENTS_DIR)
	$(CC) -o $(OUT_DIR)/$(OUT) $(OBJ) $(LIBS)
	$(RM) $(OBJ)

clean:
	$(RM) $(OBJ) $(OUT_DIR)/$(OUT)
